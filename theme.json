        }
      },
      "core/gallery": {
        "spacing": {
          "blockGap": "var:preset|spacing|small"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var:preset|spacing|small"
        }
      },
      "core/image": {
        "border": {
          "radius": "var:preset|border-radius|sm"
        }
      },
      "core/list": {
        "spacing": {
          "blockGap": "0.4rem"
        },
        "typography": {
          "lineHeight": "var:custom|typography|line-height|relaxed"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var:preset|color|main"
        },
        "typography": {
