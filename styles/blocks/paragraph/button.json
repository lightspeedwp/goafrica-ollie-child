{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "GA Button",
	"slug": "ga-button",
	"blockTypes": [
		"core/paragraph"
	],
	"description": "GoAfrica Button Paragraph",
	"styles": {
		"spacing": {
			"padding": {
				"top": "6px",
				"bottom": "6px",
				"left": "12px",
				"right": "12px"
			}
		},
		"border": {
			"radius": "5px"
		},
		"color": {
			"background": "var(--wp--preset--color--tertiary)",
			"text": "var(--wp--preset--color--primary)"
		},
		"css": "&{display:inline-flex;width:fit-content;align-items:center;line-height:1.2;} &.ga-button-links{display:flex;flex-wrap:wrap;gap:8px;padding:0;background:transparent;} &.ga-button-links a{display:inline-flex;align-items:center;padding:6px 12px;border-radius:5px;background:var(--wp--preset--color--tertiary);color:var(--wp--preset--color--primary);text-decoration:none;} &.ga-button-links a:hover,&.ga-button-links a:focus-visible{text-decoration:none;background:var(--wp--preset--color--support-sky);} &.ga-rating-stars{gap:5px;} &.ga-rating-stars .ga-rating-star{display:inline-flex;align-items:center;justify-content:center;color:var(--wp--preset--color--primary);line-height:1;} &.ga-rating-stars .ga-rating-star.is-empty{opacity:0.3;}"
	}
}
