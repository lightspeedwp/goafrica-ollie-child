{
	"$schema": "https://schemas.wp.org/wp/trunk/theme.json",
	"version": 3,
	"title": "Page Section CTA",
	"slug": "ga-page-section-cta",
	"blockTypes": [
		"core/group"
	],
	"description": "CTA styling for page sections",
	"styles": {
		"color": {
			"gradient": "linear-gradient(135deg, var(--wp--preset--color--primary) 0%, var(--wp--preset--color--primary-accent) 100%)",
			"text": "var:preset|color|base"
		},
		"spacing": {
			"padding": {
				"top": "var:preset|spacing|xx-large",
				"bottom": "var:preset|spacing|xx-large"
			},
			"margin": {
				"top": "0",
				"bottom": "0"
			},
			"blockGap": "var:preset|spacing|large"
		}
	}
}
